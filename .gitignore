# =============================================================================
# .gitignore - MetaWiki SOCIAL
# =============================================================================

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
dist/
build/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# ---- Virtuelle Umgebungen ----
venv/
.venv/
env/
.env/

# ---- Interne Steuerungsdateien (NIEMALS in Git!) ----
AUFGABEN.txt
TEST.txt
TESTS.txt
TESTERGEBNISSE.txt
BUGREPORT.md
DIAGNOSE_REPORT.md

# ---- Persoenliche / Sensible Daten ----
_USER/
.env
.env.*
credentials.json
client_secret*.json
token.json
secrets.*
*.pem
*.key
keyring/

# ---- Build-Artefakte & Releases ----
releases/
*.exe
*.msi
*.msix
*.appx
*.spec
*.temp

# ---- IDE & Editoren ----
.claude/
.vscode/
.idea/
*.swp
*.swo
*~

# ---- Betriebssystem ----
desktop.ini
Thumbs.db
.DS_Store
ehthumbs.db

# ---- Planung & Interne Doku ----
PLAN.txt

# ---- Private / Archive ----
_archive/
_private/

# ---- Logs ----
*.log

# ---- Projektspezifisch ----
output/
backups/
*.bak
*.tmp
*-ASUS-GEI.md
